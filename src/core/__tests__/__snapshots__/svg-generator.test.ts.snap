// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`SVG snapshots > floating window (no chrome) 1`] = `
"<svg width="1000" height="560" viewBox="0 0 1000 560" xmlns="http://www.w3.org/2000/svg"
  role="img" aria-label="Animated terminal showing: whoami, echo hi">
  <title>Animated terminal showing: whoami, echo hi</title>
  <desc>user@host:~$ whoami
dev
user@host:~$ echo hi
hi</desc>
  <style>
    .tt { font-family: JetBrains Mono, Fira Code, Ubuntu Mono, Consolas, Monaco, monospace; font-size: 14px; white-space: pre; }
    @keyframes scanlineScroll {
      from { transform: translateY(0); }
      to { transform: translateY(4px); }
    }
    .scanline-overlay { animation: scanlineScroll 1.2s linear infinite; }
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
  <defs>
    
    <pattern id="scanlines" patternUnits="userSpaceOnUse" width="1" height="2">
      <rect width="1" height="1" fill="transparent"/>
      <rect y="1" width="1" height="1" fill="rgba(255,255,255,0.02)"/>
    </pattern>
    
    <filter id="shadow" x="-5%" y="-5%" width="110%" height="115%">
      <feGaussianBlur in="SourceAlpha" stdDeviation="8"/>
      <feOffset dx="0" dy="6" result="offsetblur"/>
      <feFlood flood-color="#000000" flood-opacity="0.55"/>
      <feComposite in2="offsetblur" operator="in"/>
      <feMerge>
        <feMergeNode/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>

  <g filter="url(#shadow)">
    
    <rect x="0" y="0" width="1000" height="560"
          rx="12" ry="12"
          fill="#0a0e27"/>
    
    
    <defs>
      <clipPath id="terminalViewport">
        <rect x="0" y="0" width="1000" height="560"/>
      </clipPath>
    </defs>
    <rect x="0" y="0" width="1000"
          height="560" fill="#0a0e27"/>
    <g clip-path="url(#terminalViewport)">
      <g id="scrollContainer" transform="translate(12, 14)">
        
        
    <g id="line-0" transform="translate(0, 0)">
      <text class="tt" fill="#00ff9f" opacity="0">
        user@host:~$ 
        <animate attributeName="opacity" from="0" to="1" begin="0ms" dur="10ms" fill="freeze"/>
      </text>
      <text class="tt" x="109" fill="#00ff9f">
        <tspan opacity="0">w<animate attributeName="opacity" from="0" to="1" begin="0ms" dur="10ms" fill="freeze"/></tspan><tspan opacity="0">h<animate attributeName="opacity" from="0" to="1" begin="33.333333333333336ms" dur="10ms" fill="freeze"/></tspan><tspan opacity="0">o<animate attributeName="opacity" from="0" to="1" begin="66.66666666666667ms" dur="10ms" fill="freeze"/></tspan><tspan opacity="0">a<animate attributeName="opacity" from="0" to="1" begin="100ms" dur="10ms" fill="freeze"/></tspan><tspan opacity="0">m<animate attributeName="opacity" from="0" to="1" begin="133.33333333333334ms" dur="10ms" fill="freeze"/></tspan><tspan opacity="0">i<animate attributeName="opacity" from="0" to="1" begin="166.66666666666669ms" dur="10ms" fill="freeze"/></tspan>
      </text>
      
    <rect x="109" y="-12" width="8" height="14"
          fill="#00ff41" opacity="0">
      <animate attributeName="opacity" from="0" to="1" begin="0ms" dur="10ms" fill="freeze"/>
      <animate attributeName="opacity" values="1;1;0;0" dur="1000ms" begin="0ms" end="200ms" repeatCount="indefinite"/>
      <animate attributeName="opacity" to="0" begin="200ms" dur="10ms" fill="freeze"/>
      <animate attributeName="x" from="109" to="117" begin="0ms" dur="1ms" fill="freeze"/><animate attributeName="x" from="117" to="125" begin="33.333333333333336ms" dur="1ms" fill="freeze"/><animate attributeName="x" from="125" to="133" begin="66.66666666666667ms" dur="1ms" fill="freeze"/><animate attributeName="x" from="133" to="141" begin="100ms" dur="1ms" fill="freeze"/><animate attributeName="x" from="141" to="149" begin="133.33333333333334ms" dur="1ms" fill="freeze"/><animate attributeName="x" from="149" to="157" begin="166.66666666666669ms" dur="1ms" fill="freeze"/>
    </rect>
    </g>

    <g id="line-1" transform="translate(0, 25)" opacity="0">
      <animate attributeName="opacity" from="0" to="1" begin="1200ms" dur="10ms" fill="freeze"/>
      <text class="tt" fill="#e4e4e4">
        dev
      </text>
    </g>

    <g id="line-2" transform="translate(0, 50)">
      <text class="tt" fill="#00ff9f" opacity="0">
        user@host:~$ 
        <animate attributeName="opacity" from="0" to="1" begin="2450ms" dur="10ms" fill="freeze"/>
      </text>
      <text class="tt" x="109" fill="#00ff9f">
        <tspan opacity="0">e<animate attributeName="opacity" from="0" to="1" begin="2450ms" dur="10ms" fill="freeze"/></tspan><tspan opacity="0">c<animate attributeName="opacity" from="0" to="1" begin="2478.5714285714284ms" dur="10ms" fill="freeze"/></tspan><tspan opacity="0">h<animate attributeName="opacity" from="0" to="1" begin="2507.1428571428573ms" dur="10ms" fill="freeze"/></tspan><tspan opacity="0">o<animate attributeName="opacity" from="0" to="1" begin="2535.714285714286ms" dur="10ms" fill="freeze"/></tspan><tspan opacity="0"> <animate attributeName="opacity" from="0" to="1" begin="2564.285714285714ms" dur="10ms" fill="freeze"/></tspan><tspan opacity="0">h<animate attributeName="opacity" from="0" to="1" begin="2592.8571428571427ms" dur="10ms" fill="freeze"/></tspan><tspan opacity="0">i<animate attributeName="opacity" from="0" to="1" begin="2621.4285714285716ms" dur="10ms" fill="freeze"/></tspan>
      </text>
      
    <rect x="109" y="-12" width="8" height="14"
          fill="#00ff41" opacity="0">
      <animate attributeName="opacity" from="0" to="1" begin="2450ms" dur="10ms" fill="freeze"/>
      <animate attributeName="opacity" values="1;1;0;0" dur="1000ms" begin="2450ms" end="2650ms" repeatCount="indefinite"/>
      <animate attributeName="opacity" to="0" begin="2650ms" dur="10ms" fill="freeze"/>
      <animate attributeName="x" from="109" to="117" begin="2450ms" dur="1ms" fill="freeze"/><animate attributeName="x" from="117" to="125" begin="2478.5714285714284ms" dur="1ms" fill="freeze"/><animate attributeName="x" from="125" to="133" begin="2507.1428571428573ms" dur="1ms" fill="freeze"/><animate attributeName="x" from="133" to="141" begin="2535.714285714286ms" dur="1ms" fill="freeze"/><animate attributeName="x" from="141" to="149" begin="2564.285714285714ms" dur="1ms" fill="freeze"/><animate attributeName="x" from="149" to="157" begin="2592.8571428571427ms" dur="1ms" fill="freeze"/><animate attributeName="x" from="157" to="165" begin="2621.4285714285716ms" dur="1ms" fill="freeze"/>
    </rect>
    </g>

    <g id="line-3" transform="translate(0, 76)" opacity="0">
      <animate attributeName="opacity" from="0" to="1" begin="3650ms" dur="10ms" fill="freeze"/>
      <text class="tt">
        <tspan fill="#50fa7b">hi</tspan>
      </text>
    </g>
      </g>
    </g>
    <rect x="0" y="0" width="1000" height="560" fill="url(#scanlines)" pointer-events="none" opacity="0.5" class="scanline-overlay"/>
  </g>
</svg>"
`;

exports[`SVG snapshots > macOS chrome + default effects 1`] = `
"<svg width="1000" height="560" viewBox="0 0 1000 560" xmlns="http://www.w3.org/2000/svg"
