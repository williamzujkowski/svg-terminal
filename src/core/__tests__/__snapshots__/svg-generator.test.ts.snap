          fill="#e0e6ed" text-anchor="middle">
      user@terminal:~
    </text>
    
    <defs>
      <clipPath id="terminalViewport">
        <rect x="0" y="40" width="1000" height="520"/>
      </clipPath>
    </defs>
    <rect x="0" y="40" width="1000"
          height="520" fill="#0a0e27"/>
    <g clip-path="url(#terminalViewport)">
      <g id="scrollContainer" transform="translate(12, 54)" filter="url(#textGlow)">
        
        
    <g id="line-0" transform="translate(0, 0)">
      <text class="tt" fill="#00ff9f" opacity="0">
        user@host:~$ 
        <animate attributeName="opacity" from="0" to="1" begin="0ms" dur="10ms" fill="freeze"/>
      </text>
      <text class="tt" x="109" fill="#00ff9f">
        <tspan opacity="0">w<animate attributeName="opacity" from="0" to="1" begin="0ms" dur="10ms" fill="freeze"/></tspan><tspan opacity="0">h<animate attributeName="opacity" from="0" to="1" begin="33.333333333333336ms" dur="10ms" fill="freeze"/></tspan><tspan opacity="0">o<animate attributeName="opacity" from="0" to="1" begin="66.66666666666667ms" dur="10ms" fill="freeze"/></tspan><tspan opacity="0">a<animate attributeName="opacity" from="0" to="1" begin="100ms" dur="10ms" fill="freeze"/></tspan><tspan opacity="0">m<animate attributeName="opacity" from="0" to="1" begin="133.33333333333334ms" dur="10ms" fill="freeze"/></tspan><tspan opacity="0">i<animate attributeName="opacity" from="0" to="1" begin="166.66666666666669ms" dur="10ms" fill="freeze"/></tspan>
      </text>
      
