exports[`SVG snapshots > scanlines off + glow on 1`] = `
"<svg width="1000" height="560" viewBox="0 0 1000 560" xmlns="http://www.w3.org/2000/svg"
  role="img" aria-label="Animated terminal showing: whoami, echo hi">
  <title>Animated terminal showing: whoami, echo hi</title>
  <desc>user@host:~$ whoami
dev
user@host:~$ echo hi
hi</desc>
  <style>
    .tt { font-family: JetBrains Mono, Fira Code, Ubuntu Mono, Consolas, Monaco, monospace; font-size: 14px; white-space: pre; }
    @keyframes scanlineScroll {
      from { transform: translateY(0); }
