{
  "name": "svg-terminal",
  "version": "0.8.2",
  "description": "Generate animated SVG terminals for GitHub READMEs from a declarative YAML config. 46 built-in blocks, 8 themes, zero runtime deps in the output.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "svg-terminal": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "generate": "tsx src/cli.ts generate",
    "demo": "npm run build && node examples/build-demos.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "svg",
    "terminal",
    "github",
    "readme",
    "profile",
    "animation",
    "smil",
    "generator",
    "ascii",
    "cli",
    "blocks",
    "themes",
    "yaml",
    "cache",
    "static-site",
    "accessibility"
  ],
  "author": "William Zujkowski <williamzujkowski@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/williamzujkowski/svg-terminal.git"
  },
  "homepage": "https://github.com/williamzujkowski/svg-terminal",
  "bugs": {
    "url": "https://github.com/williamzujkowski/svg-terminal/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.4",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "zod": "^4.3.6"
  }
}
